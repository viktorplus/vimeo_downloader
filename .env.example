# Пример .env файла — скопируй в .env и заполни своими значениями.
# .env в git не попадает (см. .gitignore), пароль остаётся локально.

# Логин и пароль от LMS itcareerhub.de — нужны для автологина без ввода в браузере
LMS_LOGIN=your_email@example.com
LMS_PASSWORD=your_password

# Качество скачивания по умолчанию: 360, 480, 720, 1080, 1440, 2160
QUALITY=1080

# Быстрый режим: 1 = качать одним потоком (без ffmpeg-склейки, меньше время)
#                0 = качать видео+аудио раздельно и склеить через ffmpeg (макс. качество)
FAST=0

# Папки сохранения. Первая — основная (быстрая локальная), остальные — зеркала.
# После каждой скачки файл сразу копируется во все указанные пути.
# Разделитель — ';'. Если переменная не задана, используется videos/ в проекте.
# VIDEOS_DIRS=D:\путь\к\проекту\videos;Z:\videos

# Headless-режим Selenium: 1 = браузер невидим (рекомендуется при автологине,
# чтобы случайно не ввести пароль вручную поверх программного), 0 = обычное окно.
HEADLESS=1
